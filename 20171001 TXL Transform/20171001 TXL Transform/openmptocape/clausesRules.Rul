	deconstruct Clause
		copyin(Variables [list reference_id])
	construct CapeClauseList [repeat clauses]
		_ [addCopyinClause each Variables]
	by 
		CapeClauseList
end function

% Creates the cape clauses list.
function addCopyinClause Variable [reference_id]
	construct CapeClause [clauses]
		cape_set_copyin(& Variable);
	replace [repeat clauses]
		CapeClauseList [repeat clauses]
	by 
