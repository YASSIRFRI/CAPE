function addParallelFirstPrivateClauses Clause [parallel_construct_clauses]
	replace [repeat clauses]
		ClauseList [repeat clauses]

	deconstruct Clause 
		ClauseClause [omp_firstprivate_clause]

	construct NewClause [clauses]
		ClauseClause

	construct OMPClause [clauses]
		NewClause [replaceFirstPrivateClause]
	by 
		ClauseList [. OMPClause]
end function

% Handles the last private clause in the parallel construct.
function addParallelLastPrivateClauses Clause [parallel_construct_clauses]
	replace [repeat clauses]
		ClauseList [repeat clauses]

	deconstruct Clause 
		ClauseClause [omp_lastprivate_clause]

	construct NewClause [clauses]
		ClauseClause

	construct OMPClause [clauses]
		NewClause [replaceLastPrivateClause]
	by 
		ClauseList [. OMPClause]
end function

% Handles the reduction clause in the parallel construct.
function addParallelReductionClauses Clause [parallel_construct_clauses]
	replace [repeat clauses]
		ClauseList [repeat clauses]

	deconstruct Clause 
		ClauseClause [omp_reduction_clause]

	construct NewClause [clauses]
		ClauseClause

	construct OMPClause [clauses]
		NewClause [replaceReductionClause]
	by 
		ClauseList [. OMPClause]
end function

% Handles the copyin clause in the parallel construct.
function addParallelCopyinClauses Clause [parallel_construct_clauses]
	replace [repeat clauses]
