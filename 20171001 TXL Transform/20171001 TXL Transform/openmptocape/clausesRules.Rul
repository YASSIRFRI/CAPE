% Clause Transformation Rules.
% Patricia REINOSO, 29 09 2017
% 
% Revision history:
% 1.0 Initial revision - 29 09 2017
%
% Set of rules that deals with the clauses.
% Clauses taken into account:
% - Default (shared and none).
% - Shared.
% - Private.
% - First Private.
% - Last Private.
% - Reduction.
% - Copyin.
% - Copyprivate.

% Definition of clauses as the union of the 
% omp clauses and their transformation into cape.
define clauses
		[omp_clause]
	|	[cape_clause]
	|	[repeat clauses]
end define

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%					CLAUSE REPLACEMENT 				  	%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Main rule to replace omp clauses.
% Identify a omp clause and replace it by
% the appropriate cape clause.
function replaceClauses 
	replace [clauses]
		Clause [clauses]
	by
		Clause  [replaceDefaultClause] 
				[replaceSharedClause] 
			    [replacePrivateClause] 
			    [replaceFirstPrivateClause] 
			    [replaceLastPrivateClause] 
			    [replaceReductionClause]
			    [replaceCopyinClause] 
			    [replaceCopyPrivateClause]
			    [replaceNowaitClause]
end function

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%				DEFAULT CLAUSE REPLACEMENT 			  	%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Identifies the default clause and replace it by
% the appropriate cape clause. 
% Takes into account the Shared and the None parameters. 
function replaceDefaultClause 
	replace [clauses]
		DefaultClause [omp_default_clause]
	construct Clause [clauses]
		DefaultClause
	by 
		Clause [replaceDefaultNoneClause] [replaceDefaultSharedClause]
end function

% Handles the shared parameter.
function replaceDefaultSharedClause
	replace [clauses]
		default(shared)
	by
		_
end function 

% Handles the none parameter.
function replaceDefaultNoneClause
	replace [clauses]
		default(none)
	by 
		cape_set_default_none();
end function

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%				SHARED CLAUSE REPLACEMENT 			  	%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Identifies the shared clause and creates a cape 
% clauses foe each variable included in the omp clause.
function replaceSharedClause
	replace [clauses]
		Clause [omp_shared_clause]
	deconstruct Clause 
		shared(Variables [list reference_id])
	construct CapeClauseList [repeat clauses]
		_ [addSharedClause each Variables]
	by 
		CapeClauseList
end function

% Creates the cape clause list.
function addSharedClause Variable [reference_id]
	construct CapeClause [clauses]
		cape_set_shared(& Variable);
	replace [repeat clauses]
		CapeClauseList [repeat clauses]
	by 
		CapeClauseList [. CapeClause]
end function

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%				PRIVATE CLAUSE REPLACEMENT 			  	%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Identifies the private clause and creates a cape 
% clauses foe each variable included in the omp clause.
function replacePrivateClause
	replace [clauses]
		Clause [omp_private_clause]
	deconstruct Clause
		'private '( Variables [list reference_id] ')
	construct CapeClauseList [repeat clauses]
		_ [addPrivateClause each Variables]
	by 
		CapeClauseList
end function

% Creates the cape clause list.
function addPrivateClause Variable [reference_id]
	construct CapeClause [clauses]
		cape_set_private(& Variable);
	replace [repeat clauses]
		CapeClauseList [repeat clauses]
	by 
		CapeClauseList [. CapeClause]
end function

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%			FIRST PRIVATE CLAUSE REPLACEMENT 		  	%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Identifies the first private clause and creates a cape 
% clauses for each variable included in the omp clause.
function replaceFirstPrivateClause
	replace [clauses]
		Clause [omp_firstprivate_clause]

	deconstruct Clause
		firstprivate(Variables [list reference_id])

	construct CapeClauseList [repeat clauses]
		_ [addFirstPrivateClause each Variables]
	by 
		CapeClauseList
end function

% Creates the cape clause list.
function addFirstPrivateClause Variable [reference_id]
	construct CapeClause [clauses]
		cape_set_firstprivate(& Variable);
	replace [repeat clauses]
		CapeClauseList [repeat clauses]
	by 
		CapeClauseList [. CapeClause]
end function

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%			LAST PRIVATE CLAUSE REPLACEMENT 		  	%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Identifies the last private clause and creates a cape 
% clauses foe each variable included in the omp clause.
function replaceLastPrivateClause
	replace [clauses]
		Clause [omp_lastprivate_clause]
	deconstruct Clause
		lastprivate(Variables [list reference_id])
	construct CapeClauseList [repeat clauses]
		_ [addLastPrivateClause each Variables]
	by 
		CapeClauseList
end function

% Creates the cape clause list.
function addLastPrivateClause Variable [reference_id]
	construct CapeClause [clauses]
		cape_set_lastprivate(& Variable);
	replace [repeat clauses]
		CapeClauseList [repeat clauses]
	by 
		CapeClauseList [. CapeClause]
end function

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%				RREDUCTION CLAUSE REPLACEMENT 		  	%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Identifies the reduction clause and creates a cape 
% clauses foe each variable included in the omp clause.
function replaceReductionClause
	replace [clauses]
		Clause [omp_reduction_clause]
	deconstruct Clause
		reduction(Operator [omp_operator] : Variables [list reference_id])
	construct CapeClauseList [repeat clauses]
		_ [addReductionClause Operator each Variables]
	by 
		CapeClauseList
end function

% Creates the cape clauses list.
function addReductionClause Operator [omp_operator] Variable [reference_id]
	construct NewOperator [operators]
		Operator 
	construct CapeClause [clauses]
		cape_set_reduction(&Variable, NewOperator[replaceOperator]);
	replace [repeat clauses]
		CapeClauseList [repeat clauses]
	by 
		CapeClauseList [. CapeClause]
end function

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%				COPY IN CLAUSE REPLACEMENT 			  	%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Identifies the copyin clause and creates a cape 
